# PRODUCTION environment for https://digisutrasolutions.com
# Copy to the repo root on the server as `.env` and fill in. Never commit it.
#
#   cp deploy/production/env.production.example .env && nano .env

# Namespaces every container and volume so a second app on this server can
# never collide with (or accidentally wipe) this stack.
COMPOSE_PROJECT_NAME=digisutra-prod

# Public origin, no trailing slash. A ROOT domain means no basePath — this is
# the main difference from staging, which deploys under a subpath.
SITE_URL=https://digisutrasolutions.com

# 0 = allow search engines. MUST be 0 here.
# Staging uses 1; copying staging's .env and forgetting this is the easiest
# way to launch a site Google will never index.
SITE_NOINDEX=0

# The Docker network the existing Caddy container is on. Caddy reaches this
# app by container name over it, so no host port is published and nothing can
# collide with n8n / aigrowth / ollama. Find the value with:
#   docker inspect docker-setup-caddy-1 \
#     --format '{{range $k,$v := .NetworkSettings.Networks}}{{$k}}{{"\n"}}{{end}}'
CADDY_NETWORK=

# Generate BOTH fresh — do not reuse the staging values.
#   openssl rand -hex 24
DB_PASSWORD=
#   openssl rand -hex 48
AUTH_SECRET=

# --- Optional integrations -------------------------------------------------
# Contact/audit form email + workflow notifications. Without this the forms
# still capture leads to the database; they just don't email anyone.
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=Info@digisutrasolutions.com
# CONTACT_FROM_EMAIL=DigiSutra <noreply@digisutrasolutions.com>

# Admin AI content assistant + the DigiSutra Bot's model replies. Without it
# the bot falls back to its scripted intent matcher (it never breaks).
# ANTHROPIC_API_KEY=

# Free-tier fallback for the public AI tools only.
# GEMINI_API_KEY=
