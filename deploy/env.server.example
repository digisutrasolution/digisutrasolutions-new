# Server-side compose environment — copy to the repo root as `.env` on the
# server and fill in. NEVER commit the filled-in file.

# Public origin of THIS deployment (no trailing slash).
SITE_URL=https://digisutra.iqinfotech.co.in

# 1 = staging (blocks all search-engine indexing). Set 0 only on the real
# production domain.
SITE_NOINDEX=1

# Postgres password for the digisutra_cms container database.
# Generate: openssl rand -hex 24
DB_PASSWORD=

# JWT signing secret for CMS logins.
# Generate: openssl rand -hex 48
AUTH_SECRET=

# Host port Apache proxies to (loopback only).
APP_PORT=3105

# Optional — contact/audit form emails + workflow notifications.
# RESEND_API_KEY=
# CONTACT_TO_EMAIL=Info@digisutrasolutions.com
# CONTACT_FROM_EMAIL=DigiSutra <onboarding@resend.dev>

# Optional — admin AI content assistant.
# ANTHROPIC_API_KEY=
