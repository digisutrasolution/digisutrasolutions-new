generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPER_ADMIN
  DEVELOPER
  TESTER
  SEO_MANAGER
}

model User {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  passwordHash  String
  role          Role           @default(DEVELOPER)
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  pagesCreated  Page[]         @relation("PageCreatedBy")
  pagesUpdated  Page[]         @relation("PageUpdatedBy")
}

enum PageStatus {
  DRAFT
  SCHEDULED
  PUBLISHED
  ARCHIVED
}

enum WorkflowStage {
  DRAFT
  TESTING
  SEO_REVIEW
  APPROVAL
  APPROVED
}

enum BugSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum BugStatus {
  OPEN
  RESOLVED
  WONT_FIX
}

model Page {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  status         PageStatus    @default(DRAFT)
  sections       Json          @default("[]")
  seoTitle       String?
  seoDescription String?
  canonicalUrl   String?
  ogImage        String?
  noIndex        Boolean       @default(false)
  schemaJson     Json?
  publishedAt    DateTime?
  scheduledAt    DateTime?
  createdBy      User?         @relation("PageCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  createdById    String?
  updatedBy      User?         @relation("PageUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)
  updatedById    String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workflowStage  WorkflowStage @default(DRAFT)
  versions       PageVersion[]
  transitions    WorkflowTransition[]
  comments       PageComment[]
  bugs           BugReport[]

  @@index([status, publishedAt])
  @@index([workflowStage])
}

model WorkflowTransition {
  id        String        @id @default(cuid())
  page      Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId    String
  from      WorkflowStage
  to        WorkflowStage
  note      String?
  byId      String?
  byName    String?
  createdAt DateTime      @default(now())

  @@index([pageId, createdAt])
}

model PageComment {
  id          String        @id @default(cuid())
  page        Page          @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId      String
  body        String
  stageAtTime WorkflowStage
  authorId    String?
  authorName  String?
  createdAt   DateTime      @default(now())

  @@index([pageId, createdAt])
}

model BugReport {
  id             String      @id @default(cuid())
  page           Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId         String
  title          String
  description    String
  severity       BugSeverity @default(MEDIUM)
  status         BugStatus   @default(OPEN)
  screenshotUrl  String?
  reportedById   String?
  reportedByName String?
  resolvedById   String?
  resolvedByName String?
  resolvedAt     DateTime?
  createdAt      DateTime    @default(now())

  @@index([pageId, status])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String?
  link      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, readAt, createdAt])
}

model MediaAsset {
  id             String   @id @default(cuid())
  filename       String   @unique
  originalName   String
  mimeType       String
  size           Int
  width          Int?
  height         Int?
  alt            String   @default("")
  url            String
  uploadedById   String?
  uploadedByName String?
  createdAt      DateTime @default(now())

  @@index([createdAt])
}

model BlogPost {
  id             String     @id @default(cuid())
  title          String
  slug           String     @unique
  excerpt        String     @default("")
  body           String     @default("")
  category       String     @default("General")
  tags           String[]   @default([])
  coverUrl       String?
  status         PageStatus @default(DRAFT)
  publishedAt    DateTime?
  scheduledAt    DateTime?
  readingMinutes Int        @default(1)
  seoTitle       String?
  seoDescription String?
  noIndex        Boolean    @default(false)
  authorId       String?
  authorName     String?
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt
  comments       BlogComment[]

  @@index([status, publishedAt])
  @@index([category])
}

model Form {
  id          String           @id @default(cuid())
  name        String
  slug        String           @unique
  fields      Json             @default("[]")
  notifyEmail String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  submissions FormSubmission[]
}

model FormSubmission {
  id        String   @id @default(cuid())
  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)
  formId    String
  data      Json
  ip        String?
  createdAt DateTime @default(now())

  @@index([formId, createdAt])
}

enum VideoProvider {
  YOUTUBE
  VIMEO
  FILE
}

model Video {
  id             String        @id @default(cuid())
  title          String
  slug           String        @unique
  provider       VideoProvider
  videoId        String
  description    String        @default("")
  category       String        @default("General")
  thumbnailUrl   String?
  durationSec    Int?
  featured       Boolean       @default(false)
  uploadedByName String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  @@index([featured])
}

model Redirect {
  id        String   @id @default(cuid())
  fromPath  String   @unique
  toPath    String
  permanent Boolean  @default(false)
  isActive  Boolean  @default(true)
  hits      Int      @default(0)
  createdAt DateTime @default(now())
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([path, createdAt])
}

model AiGeneration {
  id          String   @id @default(cuid())
  userId      String?
  userName    String?
  kind        String
  model       String
  inputChars  Int
  outputChars Int
  createdAt   DateTime @default(now())

  @@index([createdAt])
}

model PageVersion {
  id            String   @id @default(cuid())
  page          Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  pageId        String
  version       Int
  title         String
  sections      Json
  seoSnapshot   Json
  note          String?
  createdById   String?
  createdByName String?
  createdAt     DateTime @default(now())

  @@unique([pageId, version])
}

model RefreshToken {
  id        String    @id @default(cuid())
  tokenHash String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  userAgent String?
  ip        String?
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
}

model AuditLog {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  action    String
  entity    String
  entityId  String?
  meta      Json?
  ip        String?
  createdAt DateTime @default(now())

  @@index([entity, createdAt])
  @@index([userId, createdAt])
}

enum CommentStatus {
  PENDING
  APPROVED
  REJECTED
  SPAM
}

enum AdPlacement {
  BLOG_SIDEBAR
  ARTICLE_SIDEBAR
  ARTICLE_RIGHT
  BLOG_INLINE
  SERVICE_SIDEBAR
}

model AdBanner {
  id          String      @id @default(cuid())
  title       String
  description String      @default("")
  imageUrl    String?
  targetUrl   String
  placement   AdPlacement @default(BLOG_SIDEBAR)
  active      Boolean     @default(true)
  startsAt    DateTime?
  endsAt      DateTime?
  impressions Int         @default(0)
  clicks      Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([placement, active])
}

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  source    String   @default("blog")
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model BlogComment {
  id        String        @id @default(cuid())
  post      BlogPost      @relation(fields: [postId], references: [id], onDelete: Cascade)
  postId    String
  name      String
  email     String
  body      String
  rating    Int?
  status    CommentStatus @default(PENDING)
  reply     String?
  repliedAt DateTime?
  ipHash    String?
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([postId, status])
  @@index([status, createdAt])
}

model SiteSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}

/* Dynamic navigation. MenuItem rows are the DRAFT tree the admin edits;
   the public site renders the last published snapshot (SiteSetting key
   "menu:<location>:live"), so half-finished edits never leak. */
model MenuItem {
  id         String   @id @default(cuid())
  location   String   @default("HEADER")
  parentId   String?
  parent     MenuItem?  @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children   MenuItem[] @relation("MenuTree")
  label       String
  href        String  @default("#")
  icon        String?
  group       String?
  badge       String?
  description String?
  order      Int      @default(0)
  visible    Boolean  @default(true)
  newTab     Boolean  @default(false)
  panelImage String?
  tagline    String?
  featured   Boolean  @default(false)
  /* Soft delete: trashed items keep their subtree and can be restored. */
  deletedAt  DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([location, parentId, order])
  @@index([location, deletedAt])
}

/* Dynamic service catalog: 7 categories, each with offers. Direct-edit
   (visible toggle gates the public site — no publish step needed here). */
model ServiceCategory {
  id         String         @id @default(cuid())
  slug       String         @unique
  name       String
  blurb      String         @default("")
  intro      String         @default("")
  icon       String?
  badge      String?
  image      String?
  stat       String?
  statLabel  String?
  priceFrom  String?
  marketNote String?
  /** Optional heading this service sits under in the contact picker. */
  group      String?
  order      Int            @default(0)
  visible    Boolean        @default(true)
  offers     ServiceOffer[]
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([visible, order])
}

model ServiceOffer {
  id          String          @id @default(cuid())
  category    ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId  String
  name        String
  blurb       String          @default("")
  description String          @default("")
  features    String[]        @default([])
  priceNote   String?
  image       String?
  highlight   Boolean         @default(false)
  order       Int             @default(0)
  visible     Boolean         @default(true)

  @@index([categoryId, order])
}

/* Dynamic pricing: plans + comparison-matrix rows + one-off rate card. */
model PricingPlan {
  id             String   @id @default(cuid())
  name           String
  price          String
  quarterlyPrice String?
  period         String   @default("/mo")
  tagline        String   @default("")
  marketNote     String?
  cta            String   @default("Choose plan")
  featured       Boolean  @default(false)
  order          Int      @default(0)
  visible        Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PricingRow {
  id      String  @id @default(cuid())
  label   String
  tooltip String?
  values  Json    // string per plan, aligned to visible plan order
  order   Int     @default(0)
  visible Boolean @default(true)
}

model RateCardRow {
  id         String  @id @default(cuid())
  label      String
  price      String
  marketNote String?
  order      Int     @default(0)
  visible    Boolean @default(true)
}

model FaqItem {
  id       String  @id @default(cuid())
  question String
  lead     String  @default("")
  rest     String  @default("")
  category String  @default("General")
  icon     String?
  featured Boolean @default(false)
  order    Int     @default(0)
  visible  Boolean @default(true)

  @@index([order])
}

enum LeadSource {
  CONTACT
  AUDIT
  ESTIMATOR
  SUTRABOT
}

enum LeadStatus {
  NEW
  VERIFIED
  QUALIFIED
  WON
  LOST
}

model Lead {
  id        String     @id @default(cuid())
  name      String
  whatsapp  String
  email     String?
  website   String?
  services  String[]   @default([])
  budget    String?
  timeline  String?
  message   String?
  /** Which desk the enquiry asked for: SALES | SUPPORT | GENERAL. */
  department String?
  /** Answer to "How did you find us?" — attribution, countable in admin. */
  heardFrom String?
  source    LeadSource @default(CONTACT)
  status    LeadStatus @default(NEW)
  verified  Boolean    @default(false)
  notes     String?
  ipHash    String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@index([status, createdAt])
  @@index([whatsapp])
}

model MenuVersion {
  id         String   @id @default(cuid())
  location   String
  snapshot   Json
  authorName String?
  createdAt  DateTime @default(now())

  @@index([location, createdAt])
}

/// Social proof — every row is a factual claim about a real client, so
/// nothing here is seeded with sample data. Empty tables render nothing.
model Testimonial {
  id        String   @id @default(cuid())
  quote     String
  name      String
  role      String   @default("")
  rating    Int      @default(5)
  order     Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible, order])
}

model ClientLogo {
  id        String   @id @default(cuid())
  name      String
  /// Optional logo file; without one the name renders as a wordmark.
  imageUrl  String?
  websiteUrl String?
  order     Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible, order])
}

model CaseStudy {
  id        String   @id @default(cuid())
  slug      String   @unique
  client    String
  title     String
  industry  String   @default("")
  /// Web | Marketing | AI — drives the /work filter tabs.
  category  String   @default("Web")
  services  String[] @default([])
  challenge String   @default("")
  solution  String   @default("")
  result    String   @default("")
  /// [{ value, label }] — shown as the metric row on the card.
  metrics   Json     @default("[]")
  timeframe String   @default("")
  image     String?
  order     Int      @default(0)
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([visible, order])
}
