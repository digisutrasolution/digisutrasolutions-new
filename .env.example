# ── Database ────────────────────────────────────────────────────────────
# Local dev: the portable PostgreSQL server at ../pgsql (npm run db:start)
# Production: a managed Postgres (Neon / Supabase / RDS) connection string
DATABASE_URL="postgresql://postgres:digisutra_dev@localhost:5433/digisutra_cms"

# ── Auth ────────────────────────────────────────────────────────────────
# HS256 secret for access-token signing. Generate a fresh one for prod:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET=""

# ── AI content assistant (Phase 5) ──────────────────────────────────────
# Enables /api/ai/generate and the "AI assist" panels. Without it the
# endpoint returns a clear 503 and the rest of the CMS works normally.
# ANTHROPIC_API_KEY=""

# ── Email (contact form + workflow notifications) ───────────────────────
# Without a key, emails are skipped silently; in-app notifications still work.
# RESEND_API_KEY=""
# CONTACT_TO_EMAIL="hello@digisutra.com"
# CONTACT_FROM_EMAIL="DigiSutra <onboarding@resend.dev>"

# ── Media storage (production) ──────────────────────────────────────────
# When set, uploads go to Vercel Blob instead of public/uploads (which is
# ephemeral on serverless). Create a Blob store in the Vercel dashboard.
# BLOB_READ_WRITE_TOKEN=""
